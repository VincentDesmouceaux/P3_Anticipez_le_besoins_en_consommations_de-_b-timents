   "source": [
    "aberrants = df[\n",
    "    (df[\"PropertyGFATotal\"] <= 0) |\n",
    "    (df[\"NumberofFloors\"] <= 0) |\n",
    "    (df[\"SiteEnergyUse(kBtu)\"] <= 0)\n",
    "]\n",
    "\n",
    "print(\"Nombre de lignes potentiellement aberrantes :\", aberrants.shape[0])\n",
    "aberrants.head()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 140,
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Dimensions finales après nettoyage : (1531, 44)\n"
     ]
    }
   ],
   "source": [
    "df = df[\n",
    "    (df[\"PropertyGFATotal\"] > 0) &\n",
    "    (df[\"NumberofFloors\"] > 0) &\n",
    "    (df[\"SiteEnergyUse(kBtu)\"] > 0)\n",
