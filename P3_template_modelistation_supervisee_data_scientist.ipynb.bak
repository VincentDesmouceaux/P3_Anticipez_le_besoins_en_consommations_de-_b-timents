   "source": [
    "property_type_col = None\n",
    "\n",
    "if \"PrimaryPropertyType\" in df.columns:\n",
    "    property_type_col = \"PrimaryPropertyType\"\n",
    "elif \"EPAPropertyType\" in df.columns:\n",
    "    property_type_col = \"EPAPropertyType\"\n",
    "else:\n",
    "    raise KeyError(f\"Aucune colonne de type propriété trouvée. Colonnes disponibles : {list(df.columns)}\")\n",
    "\n",
    "pivot_property = pd.pivot_table(\n",
    "    df,\n",
    "    index=\"DataYear\",\n",
    "    columns=property_type_col,\n",
    "    values=\"SiteEnergyUse(kBtu)\",\n",
    "    aggfunc=\"mean\"\n",
    ")\n",
    "\n",
    "pivot_property.round(2)"
   ]
  },
