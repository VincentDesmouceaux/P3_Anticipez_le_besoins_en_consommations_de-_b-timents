   "source": [
    "pivot_property = pd.pivot_table(\n",
    "    df,\n",
    "    index=\"DataYear\",\n",
    "    columns=\"PrimaryPropertyType\",\n",
    "    values=\"SiteEnergyUse(kBtu)\",\n",
    "    aggfunc=\"mean\"\n",
    ")\n",
    "\n",
    "pivot_property.round(2)"
   ]
  },
